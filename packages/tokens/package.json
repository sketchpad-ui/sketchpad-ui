{
  "name": "@sketchpad/tokens",
  "version": "0.1.0",
  "description": "Cross-framework Neubrutalist design tokens for Sketchpad UI",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./tokens.json"
  },
  "files": ["dist", "tokens.json"],
  "scripts": {
    "build": "tsc --noEmit false && node scripts/generate-css.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --config ../../vitest.config.ts --environment node"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
