{
  "name": "@sketchpad/sketch-core",
  "version": "0.1.0",
  "description": "Seeded sketch path rendering engine for Sketchpad UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --config ../../vitest.config.ts --environment node"
  },
  "dependencies": {
    "@sketchpad/tokens": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
