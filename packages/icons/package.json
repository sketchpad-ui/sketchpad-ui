{
  "name": "@sketchpad/icons",
  "version": "0.1.0",
  "description": "Hand-drawn style icons for Sketchpad UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@sketchpad/sketch-core": "workspace:*",
    "@sketchpad/tokens": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "tsup": "^8.3.5"
  }
}
